# API settings
DEBUG=false

# Security settings
SECRET_KEY=your-secret-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7 days

# Database settings
DATABASE_URL=sqlite:///./medical_research_synthesizer.db
# For PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/medical_research_synthesizer

# Cache settings
# REDIS_URL=redis://localhost:6379/0
CACHE_TTL=3600  # 1 hour

# External API settings
NCBI_EMAIL=your.email@example.com
NCBI_API_KEY=your-ncbi-api-key-here

# File paths
IMPACT_FACTOR_SOURCE=journal_impact_factors.csv
KB_DIR=knowledge_bases

# Model settings
USE_GPU=true
BIOMEDLM_MODEL=microsoft/BioMedLM

# Ray settings
# RAY_ADDRESS=ray://localhost:10001
# RAY_NUM_CPUS=4
# RAY_NUM_GPUS=1

# Logging settings
LOG_LEVEL=INFO

# Graph database settings
GRAPH_DB_TYPE=memgraph
MEMGRAPH_HOST=localhost
MEMGRAPH_PORT=7687
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j
