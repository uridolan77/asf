import time
import logging
import asyncio
from typing import Dict, Any, List, Optional, Tuple
import numpy as np  # Import numpy

# Layer 1 imports
from layer1_knowledge_substrate.knowledge_substrate_layer import KnowledgeSubstrateLayer
from layer1_knowledge_substrate.perception.entity import PerceptualEntity
from layer1_knowledge_substrate.core.enums import PerceptualInputType

# Layer 2 imports
from layer2_autopoietic_maintanance.autopoietic_maintenance_layer import SymbolicFormationLayer, SymbolConfidenceState
from layer2_autopoietic_maintanance.predictive_factory import create_predictive_layer2, convert_to_predictive  # For Seth's enhancements
from layer2_autopoietic_maintanance.symbolic_layer_components import PredictiveSymbolRecognizer, SymbolicPredictiveProcessor, CounterfactualAutocatalyticNetwork

class KSL_AML_Interface:
    """
    Interface layer facilitating communication between Layer 1 (Knowledge Substrate)
    and Layer 2 (Autopoietic Maintenance Layer/Symbolic Formation).

    Key Responsibilities:
    - Receiving processed perceptual input (entities) from Layer 1.
    - Formatting and transmitting data to Layer 2 for symbol formation/recognition.
    - Receiving symbol information (new, recognized) from Layer 2.
    - Providing feedback to Layer 1 about symbol relevance/confidence.
    - Handling asynchronous communication and error cases.
    - Implementing Seth's predictive processing by exchanging prediction data.
    """

    def __init__(self, layer1: KnowledgeSubstrateLayer, layer2: SymbolicFormationLayer,
                 use_predictive_layer2: bool = False, config: Optional[Dict[str, Any]] = None):
        """
        Initializes the interface with instances of Layer 1 and Layer 2.

        Args:
            layer1: Instance of KnowledgeSubstrateLayer.
            layer2: Instance of SymbolicFormationLayer.
            use_predictive_layer2: Whether to use predictive processing enhancements in Layer 2.
            config: Optional configuration dictionary.
        """
        self.layer1 = layer1
        self.layer2 = layer2
        self.config = config or {}
        self.logger = logging.getLogger("KSL_AML_Interface")

        # Seth's enhancements - Predictive Processing
        self.use_predictive_layer2 = use_predictive_layer2
        if self.use_predictive_layer2:
            self.logger.info("Initializing with Predictive Layer 2 (Seth's Enhancements)")
            #  Use factory to create a predictive Layer 2
            self.layer2 = create_predictive_layer2(self.config.get("layer2_config"))

        # Feedback loop statistics
        self.feedback_stats = {
            "confidence_updates_sent": 0,
            "relevance_predictions_sent": 0,
            "prediction_requests_sent": 0,
        }

        # Asyncio setup for concurrent operations
        self.loop = asyncio.get_event_loop()  # or asyncio.new_event_loop() if needed


    def _entity_to_dict(self, entity: PerceptualEntity) -> Dict[str, Any]:
        """Converts a PerceptualEntity object to a dictionary for Layer 2."""
        feature_dict = {}
        for feature_name, feature in entity.features.items():
            feature_dict[feature_name] = feature.value

        return {
            'entity_id': entity.id,
            'input_type': entity.input_type.value,  # Convert enum to string
            'features': feature_dict,
            'confidence_state': entity.confidence_state.value, # And convert to strings
            'confidence_score': entity.confidence_score,
             #Include temporal metadata.
            'timestamp': entity.temporal_metadata.creation_time,
            'last_access': entity.temporal_metadata.last_access_time
        }
    def _dict_to_entity(self, entity_data: Dict[str, Any]) -> PerceptualEntity:
        """Converts dictionary back to a PerceptualEntity object for Layer 1."""
        try:
            input_type_enum = PerceptualInputType(entity_data['input_type'])
        except ValueError:
            self.logger.error(f"Invalid input_type: {entity_data['input_type']}")
            return None  # Or raise an exception

        entity = PerceptualEntity(entity_data['entity_id'], input_type_enum)

        # Add all features
        for feature_name, value in entity_data['features'].items():
            # Assuming 'value' already contains 'value' and optionally 'importance'
             # If 'importance' exists, use it as confidence; otherwise default to 0.5.
            if isinstance(value, dict) and 'value' in value:  # Seth's weighted features
                confidence = value.get('importance', 0.5)  # Default to 0.5 if no 'importance'
                actual_value = value['value']
                entity.add_feature(feature_name, actual_value, confidence=confidence)  #Correctly passing values to the features

            else:
                entity.add_feature(feature_name, value) # Fallback

        #Update confidece
        entity.confidence_score = entity_data.get('confidence_score', 0.5) #Default to 0.5 if missing
        entity.confidence_state = entity_data.get('confidence_state', 'UNVERIFIED')

        return entity


    async def send_to_layer2(self, perceptual_data: Dict[str, PerceptualEntity], context: Optional[Dict[str, Any]] = None) -> Dict[str, Any]:
        """
        Sends processed perceptual data from Layer 1 to Layer 2.

        Args:
            perceptual_data:  A dictionary mapping entity IDs to PerceptualEntity objects.
            context: An optional dictionary representing the processing context.

        Returns:
             A dictionary containing the results from Layer 2 processing.
        """
        self.logger.debug(f"Sending {len(perceptual_data)} entities to Layer 2.")

        # Convert PerceptualEntities to dictionaries
        layer2_input = {entity_id: self._entity_to_dict(entity) for entity_id, entity in perceptual_data.items()}

        # Call Layer 2 processing (async)
        try:
            layer2_result = await self.layer2.process_perceptual_input(layer2_input, context)
            self.logger.debug(f"Received response from Layer 2: {layer2_result}")
            return layer2_result
        except Exception as e:
            self.logger.error(f"Error in Layer 2 processing: {e}", exc_info=True)
            return {"error": str(e)}


    async def send_feedback_to_layer1(self, symbol_data: List[Dict[str, Any]]) -> None:
        """
        Sends feedback (confidence updates, relevance predictions) from Layer 2 to Layer 1.

        Args:
            symbol_data: List of dictionaries, each representing a symbol with
                         'symbol_id', 'confidence', and optionally 'predicted_relevance'.
        """
        self.logger.debug(f"Sending feedback for {len(symbol_data)} symbols to Layer 1.")

        for symbol_info in symbol_data:
            symbol_id = symbol_info.get('symbol_id')

            # Find the corresponding entity IDs from Layer 1 using the mapping
            entity_ids = [entity_id for entity_id, s_id in self.layer2.recognized_symbol_mapping.items() if s_id == symbol_id]

            if not entity_ids:
                # If there's no direct mapping, check if we can get the source entities from Layer 2
                if symbol_id in self.layer2.symbols:
                   symbol = self.layer2.symbols[symbol_id]
                   entity_ids = symbol.source_entities # get the saved sources
                else:
                    self.logger.warning(f"Symbol ID {symbol_id} not found in mapping or symbols.")
                    continue # Skip if no entities can be found


            confidence = symbol_info.get('confidence')
            if confidence is not None:
                for entity_id in entity_ids:
                    self.layer1.update_entity_confidence(entity_id, confidence > 0.5, context={"confidence": confidence})  # Simplified
                    self.feedback_stats["confidence_updates_sent"] += 1


            predicted_relevance = symbol_info.get('predicted_relevance')
            if predicted_relevance is not None:
                # Assuming a context can be provided or derived for relevance predictions
                context = symbol_info.get('context', {})  # Or derive a suitable context
                for entity_id in entity_ids:
                  self.layer1.predict_entity_relevance(entity_id, context)
                  self.feedback_stats["relevance_predictions_sent"] += 1

    async def request_predictions_from_layer2(self, context: Dict[str, Any]) -> Dict[str, Any]:
        """
        Requests predictions from Layer 2 about expected perceptual input.

        Args:
            context: The context for which predictions are requested.

        Returns:
            A dictionary of predictions from Layer 2.
        """
        if self.use_predictive_layer2:
            self.logger.debug(f"Requesting perceptual predictions from Layer 2.")
            predictions = await self.layer2.generate_perceptual_predictions(context)
            self.feedback_stats["prediction_requests_sent"] += 1
            self.logger.debug(f"Layer 2 Predicted: {predictions}")
            return predictions
        else:
            self.logger.warning("Predictive Layer 2 is not enabled. Cannot request predictions.")
            return {}  # Return empty dict if not using predictive processing


    async def receive_and_process_input(self, input_data: Any, input_type: PerceptualInputType, context: Optional[Dict[str, Any]] = None) -> Tuple[Optional[str], Optional[Dict[str, Any]]]:
      """
      Receives and processes input from Layer 1, including sending to Layer 2.

      Args:
          input_data: The raw input data.
          input_type: The type of the input (e.g., TEXT, IMAGE).
          context: Optional processing context.

      Returns:
        Tuple: (entity_id of processed entity, result dictionary from layer 2) or (None, None) on error.
      """
      try:
          entity_id = self.layer1.process_input(input_data, input_type, context)
          if entity_id:
              entity = self.layer1.get_entity(entity_id)
              if entity:
                  layer2_result = await self.send_to_layer2({entity_id: entity}, context)
                  return entity_id, layer2_result #Return the entity id and layer 2 result
              else:
                  self.logger.error(f"Failed to retrieve entity with ID {entity_id} from Layer 1.")
                  return None, None
          else:
              self.logger.error(f"Failed to process input in Layer 1. Input type: {input_type}")
              return None, None
      except Exception as e:
          self.logger.error(f"Error processing input: {e}", exc_info=True)
          return None, None

    async def run_full_integration_cycle(self, perceptual_data: Dict[str, PerceptualEntity], context: Dict[str, Any]):
        """Runs a complete integration cycle including symbol formation and operational closure."""
        start_time = time.time()

        # 1. Process Perceptual Input and potentially form/recognize symbols.
        layer2_results = await self.send_to_layer2(perceptual_data, context)
        self.logger.debug(f"Layer 2 initial processing results: {layer2_results}")

        # 2. Run Layer 2 integration (autocatalysis, operational closure)
        layer2_integration_results = await self.layer2.run_integration_cycle()
        self.logger.debug(f"Layer 2 integration cycle results: {layer2_integration_results}")

        # 3. Send feedback to Layer 1
        # Prepare feedback data - Example: Collect new or significantly changed symbols.
        feedback_data = []
        for symbol_id, symbol in self.layer2.symbols.items():
            # Example criterion: newly created or confidence significantly changed.
            if symbol.created_at > start_time or symbol.confidence_state == SymbolConfidenceState.CANONICAL: #just an example
                 feedback_data.append({
                    "symbol_id": symbol_id,
                    "confidence": symbol.confidence,
                    "predicted_relevance": 0.8  # Placeholder, fill in as needed
                 })

        await self.send_feedback_to_layer1(feedback_data)

        # 4. Return a comprehensive report
        return {
                "status": "success",
                "layer2_initial_results": layer2_results,
                "layer2_integration_results": layer2_integration_results,
                "feedback_sent": feedback_data,
                "total_processing_time": time.time() - start_time,
        }

    def convert_layer2_to_predictive(self):
      """
      Converts standard Layer 2 components to predictive variants.
      Must be called *before* any data processing.  Ideally during initialization
      if you intend to start with predictive processing.
      """
      if not self.use_predictive_layer2:
          self.logger.warning("Predictive Layer 2 mode is not enabled. Conversion has no effect.")
          return

      if self.layer2.symbols:
          self.logger.warning("Layer 2 already contains symbols.  Conversion may lead to unexpected behavior.")

      # Convert existing symbols and potentials to predictive variants
      self.layer2 = convert_to_predictive(self.layer2)

      # Re-initialize the recognizer (if it needs specific predictive handling)
      self.layer2.recognizer = PredictiveSymbolRecognizer(threshold=self.config.get("recognition_threshold", 0.7))
      #Re-initialize the autocatalitic network
      self.layer2.autocatalytic_network = CounterfactualAutocatalyticNetwork(self.layer2.nonlinearity_tracker)
      #Re-initialize the predictive processor
      self.layer2.predictive_processor = SymbolicPredictiveProcessor()

      self.logger.info("Layer 2 components converted to predictive variants.")


